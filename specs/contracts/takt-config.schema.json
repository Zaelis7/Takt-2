{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://takt.dev/schemas/takt-config-v1alpha1.json",
  "title": "Takt declarative project configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "takt.dev/v1alpha1" },
    "kind": { "const": "TaktProject" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization", "project", "source"],
      "properties": {
        "organization": { "$ref": "#/$defs/slug" },
        "project": { "$ref": "#/$defs/slug" },
        "source": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200,
          "description": "Stable owner identity, for example git:https://example/repo//prod/takt.yaml"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "monitors": {
          "type": "array",
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/monitor" }
        },
        "notificationChannels": {
          "type": "array",
          "maxItems": 500,
          "items": { "$ref": "#/$defs/notificationChannel" }
        },
        "maintenances": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/maintenance" }
        },
        "statusPages": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/statusPage" }
        }
      }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"
    },
    "duration": {
      "type": "string",
      "pattern": "^[1-9][0-9]*(ms|s|m|h|d)$"
    },
    "checkDuration": {
      "type": "string",
      "pattern": "^(?:(?:[1-9]|[1-9][0-9]{1,4}|[12][0-9]{5}|300000)ms|(?:[1-9]|[1-9][0-9]|[12][0-9]{2}|300)s|[1-5]m)$",
      "description": "Duration from 1 millisecond through 5 minutes."
    },
    "pushGraceDuration": {
      "oneOf": [
        { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,6}|[1-7][0-9]{7}|8[0-5][0-9]{6}|86[0-3][0-9]{5}|86400000)ms$" },
        { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,3}|[1-7][0-9]{4}|8[0-5][0-9]{3}|86[0-3][0-9]{2}|86400)s$" },
        { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,2}|1[0-3][0-9]{2}|14[0-3][0-9]|1440)m$" },
        { "type": "string", "pattern": "^(?:0|[1-9]|1[0-9]|2[0-4])h$" },
        { "type": "string", "pattern": "^[01]d$" }
      ],
      "description": "Duration from zero through 24 hours."
    },
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secretRef"],
      "properties": {
        "secretRef": { "$ref": "#/$defs/slug" },
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "default": "value"
        }
      }
    },
    "resolverUri": {
      "type": "string",
      "format": "uri",
      "pattern": "^(?:udp|tcp|tls)://(?![^/?#]*@)[^/?#]+/?$",
      "maxLength": 2048,
      "description": "Authority-only DNS resolver URI without credentials, path, query, or fragment."
    },
    "addressFamily": {
      "enum": ["auto", "ipv4", "ipv6"],
      "default": "auto",
      "description": "Address family used to connect to the target, resolver, or proxy; it does not change a DNS record type."
    },
    "proxyBasicAuth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["username", "password"],
      "properties": {
        "username": { "$ref": "#/$defs/secretRef" },
        "password": { "$ref": "#/$defs/secretRef" }
      }
    },
    "proxySpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^(?:http|https|socks5)://(?![^/?#]*@)[^/?#]+/?$",
          "maxLength": 2048,
          "description": "Authority-only proxy URL; credentials are forbidden in the URL."
        },
        "auth": { "$ref": "#/$defs/proxyBasicAuth" }
      }
    },
    "httpValue": {
      "oneOf": [
        { "type": "string", "maxLength": 1048576 },
        { "$ref": "#/$defs/secretRef" }
      ]
    },
    "jsonPointerAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pointer", "value"],
      "properties": {
        "pointer": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "value": { "type": "string", "maxLength": 4194304 }
      }
    },
    "httpAuth": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "username", "password"],
          "properties": {
            "type": { "const": "basic" },
            "username": { "$ref": "#/$defs/secretRef" },
            "password": { "$ref": "#/$defs/secretRef" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "token"],
          "properties": {
            "type": { "const": "bearer" },
            "token": { "$ref": "#/$defs/secretRef" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "clientCertificate", "clientKey"],
          "properties": {
            "type": { "const": "mtls" },
            "clientCertificate": { "$ref": "#/$defs/secretRef" },
            "clientKey": { "$ref": "#/$defs/secretRef" }
          }
        }
      ]
    },
    "labelSelector": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_.-]{0,62}$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "maxProperties": 20
    },
    "monitorSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "matchTags": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 50 }
        },
        "matchSlugs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/slug" }
        }
      },
      "anyOf": [
        { "required": ["matchTags"] },
        { "required": ["matchSlugs"] }
      ]
    },
    "probePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["any", "all", "quorum"] },
        "minSuccess": { "type": "integer", "minimum": 1, "maximum": 100 }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "quorum" } }, "required": ["mode"] },
          "then": { "required": ["minSuccess"] }
        }
      ]
    },
    "monitor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "type", "target"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "description": { "type": "string", "maxLength": 2000 },
        "type": { "enum": ["http", "tcp", "dns", "icmp", "tls", "push", "browser"] },
        "enabled": { "type": "boolean", "default": true },
        "interval": { "$ref": "#/$defs/duration", "default": "60s" },
        "timeout": { "$ref": "#/$defs/duration", "default": "10s" },
        "failureThreshold": { "type": "integer", "minimum": 1, "maximum": 20, "default": 3 },
        "recoveryThreshold": { "type": "integer", "minimum": 1, "maximum": 20, "default": 2 },
        "tags": {
          "type": "array",
          "maxItems": 50,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 50 }
        },
        "probeSelector": { "$ref": "#/$defs/labelSelector" },
        "probePolicy": { "$ref": "#/$defs/probePolicy" },
        "notificationChannels": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/slug" }
        },
        "target": { "type": "object" }
      },
      "allOf": [
        { "if": { "properties": { "type": { "const": "http" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/httpTarget" } } } },
        { "if": { "properties": { "type": { "const": "tcp" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/tcpTarget" } } } },
        { "if": { "properties": { "type": { "const": "dns" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/dnsTarget" } } } },
        { "if": { "properties": { "type": { "const": "icmp" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/icmpTarget" } } } },
        { "if": { "properties": { "type": { "const": "tls" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/tlsTarget" } } } },
        { "if": { "properties": { "type": { "const": "push" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/pushTarget" } } } },
        { "if": { "properties": { "type": { "const": "browser" } } }, "then": { "properties": { "target": { "$ref": "#/$defs/browserTarget" } } } }
      ]
    },
    "httpTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https?://", "maxLength": 2048 },
        "method": { "enum": ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"], "default": "GET" },
        "headers": {
          "type": "object",
          "maxProperties": 50,
          "propertyNames": { "minLength": 1, "maxLength": 256 },
          "additionalProperties": {
            "oneOf": [
              { "type": "string", "maxLength": 8192 },
              { "$ref": "#/$defs/secretRef" }
            ]
          }
        },
        "body": {
          "$ref": "#/$defs/httpValue"
        },
        "expectedStatus": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 100, "maximum": 599, "default": 200 },
            "max": { "type": "integer", "minimum": 100, "maximum": 599, "default": 399 }
          }
        },
        "followRedirects": { "type": "integer", "minimum": 0, "maximum": 10, "default": 5 },
        "verifyTls": { "type": "boolean", "default": true },
        "httpVersion": { "enum": ["auto", "http1_1", "http2"], "default": "auto" },
        "bodyContains": { "type": "string", "maxLength": 4194304 },
        "bodyMatches": { "type": "string", "maxLength": 4194304 },
        "jsonPointerEquals": { "$ref": "#/$defs/jsonPointerAssertion" },
        "jsonPointerContains": { "$ref": "#/$defs/jsonPointerAssertion" },
        "maxResponseTime": { "$ref": "#/$defs/checkDuration" },
        "responseBodyLimitBytes": { "type": "integer", "minimum": 1, "maximum": 1048576, "default": 1048576 },
        "auth": { "$ref": "#/$defs/httpAuth" },
        "proxy": { "$ref": "#/$defs/proxySpec" },
        "resolver": { "$ref": "#/$defs/resolverUri" },
        "addressFamily": { "$ref": "#/$defs/addressFamily" }
      }
    },
    "tcpTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "port"],
      "properties": {
        "host": { "type": "string", "minLength": 1, "maxLength": 253 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "sendText": { "type": "string", "maxLength": 4096 },
        "expectPrefix": { "type": "string", "maxLength": 4096 },
        "proxy": { "$ref": "#/$defs/proxySpec" },
        "resolver": { "$ref": "#/$defs/resolverUri" },
        "addressFamily": { "$ref": "#/$defs/addressFamily" }
      }
    },
    "dnsTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "recordType"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 253 },
        "recordType": { "enum": ["A", "AAAA", "CNAME", "MX", "TXT", "NS", "SOA", "CAA"] },
        "expectedValues": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "maxLength": 4096 }
        },
        "resolver": { "$ref": "#/$defs/resolverUri" },
        "addressFamily": { "$ref": "#/$defs/addressFamily" },
        "expectedRcode": { "enum": ["NOERROR", "NXDOMAIN", "SERVFAIL", "REFUSED"], "default": "NOERROR" },
        "minimumAnswers": { "type": "integer", "minimum": 0, "maximum": 100, "default": 1 },
        "valueMatch": { "enum": ["exact", "contains"], "default": "contains" }
      }
    },
    "icmpTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host"],
      "properties": {
        "host": { "type": "string", "minLength": 1, "maxLength": 253 },
        "packets": { "type": "integer", "minimum": 1, "maximum": 5, "default": 3 },
        "requiredSuccesses": { "type": "integer", "minimum": 1, "maximum": 5, "default": 1 },
        "maxLatencyMs": { "type": "integer", "minimum": 1, "maximum": 300000 },
        "resolver": { "$ref": "#/$defs/resolverUri" },
        "addressFamily": { "$ref": "#/$defs/addressFamily" }
      }
    },
    "tlsTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host"],
      "properties": {
        "host": { "type": "string", "minLength": 1, "maxLength": 253 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 443 },
        "serverName": { "type": "string", "minLength": 1, "maxLength": 253 },
        "warningDays": { "type": "integer", "minimum": 1, "maximum": 3650, "default": 30 },
        "criticalDays": { "type": "integer", "minimum": 0, "maximum": 3650, "default": 7 },
        "proxy": { "$ref": "#/$defs/proxySpec" },
        "resolver": { "$ref": "#/$defs/resolverUri" },
        "addressFamily": { "$ref": "#/$defs/addressFamily" }
      }
    },
    "pushTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "grace": { "$ref": "#/$defs/pushGraceDuration", "default": "60s" },
        "allowGet": { "type": "boolean", "default": false }
      }
    },
    "browserStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "action": { "enum": ["navigate", "click", "fill", "wait", "assertText", "assertUrl", "assertStatus"] },
        "selector": { "type": "string", "maxLength": 1000 },
        "value": {
          "oneOf": [
            { "type": "string", "maxLength": 4096 },
            { "$ref": "#/$defs/secretRef" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "fill" } }, "required": ["action"] },
          "then": {
            "required": ["selector", "value"],
            "properties": { "value": { "$ref": "#/$defs/secretRef" } }
          }
        }
      ]
    },
    "browserTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startUrl", "steps"],
      "properties": {
        "startUrl": { "type": "string", "format": "uri", "pattern": "^https?://", "maxLength": 2048 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "$ref": "#/$defs/browserStep" }
        },
        "maxNetworkResponseBytes": { "type": "integer", "minimum": 1, "maximum": 10485760, "default": 10485760 },
        "screenshotOnFailureMaxBytes": { "type": "integer", "minimum": 0, "maximum": 10485760, "default": 1048576 },
        "proxy": { "$ref": "#/$defs/proxySpec" },
        "resolver": { "$ref": "#/$defs/resolverUri" },
        "addressFamily": { "$ref": "#/$defs/addressFamily" }
      }
    },
    "notificationChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "type", "config"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "type": { "enum": ["webhook", "smtp", "slack", "discord", "telegram"] },
        "enabled": { "type": "boolean", "default": true },
        "config": {
          "type": "object",
          "description": "Type-specific non-secret values and secretRef objects.",
          "maxProperties": 50
        }
      }
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "startsAt", "endsAt", "monitorSelector"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "startsAt": { "type": "string", "format": "date-time" },
        "endsAt": { "type": "string", "format": "date-time" },
        "timezone": { "type": "string", "default": "UTC" },
        "behavior": { "enum": ["suppressNotifications", "markMaintenance"], "default": "markMaintenance" },
        "monitorSelector": { "$ref": "#/$defs/monitorSelector" }
      }
    },
    "statusPage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "visibility", "groups"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "visibility": { "enum": ["public", "token"] },
        "locale": { "enum": ["de", "en"], "default": "en" },
        "groups": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "monitors"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 120 },
              "monitors": {
                "type": "array",
                "maxItems": 500,
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/slug" }
              }
            }
          }
        }
      }
    }
  }
}
